{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "noEmitOnError": true,
        "lib": [
            "ES2020",
            "DOM"
        ]
    },
    "include": ["src/index.ts"],
    "exclude": ["node_modules", "dist"]
}
